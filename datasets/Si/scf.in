&control
    calculation = 'scf'
    restart_mode = 'from_scratch'
    prefix = 'silicon'
    tstress = .true.
    tprnfor = .true.
    pseudo_dir = 'pseudo/'
    outdir = './tmp/'
    verbosity = 'high'
/
&system
    ibrav = 0
    nat = 2
    ntyp = 1
    ecutwfc = 100
/
&electrons
    diagonalization = 'david'
    mixing_mode = 'plain'
    mixing_beta = 0.3
    conv_thr = 1.0e-12
/
ATOMIC_SPECIES
    Si  28.085   Si.upf
ATOMIC_POSITIONS crystal 
   Si 0.000000 0.000000 0.000000
   Si 0.750000 0.750000 0.750000
K_POINTS {automatic}
    8 8 8 0 0 0
CELL_PARAMETERS angstrom
   -2.715260 0.000000 2.715260
   0.000000 2.715260 2.715260
   -2.715260 2.715260 0.000000
